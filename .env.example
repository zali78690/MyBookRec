# Copy to .env and fill in values. The .env file is gitignored.
#
# Every variable here is consumed by mybookrec.settings.Settings — never read directly
# via os.environ from application code.

# --- ingestion APIs ---
# Required to run `mybookrec.ingest.cli fetch --source google_books` or `--source both`.
# Get a free key (1k req/day) at https://console.developers.google.com/apis/credentials.
GOOGLE_BOOKS_API_KEY=

# Open Library has no key requirement but asks every client to identify itself.
# Override only if you want a different UA in the bronze JSONL request logs.
# OPENLIBRARY_USER_AGENT="MyBookRec/0.1 (https://github.com/zali78690/MyBookRec)"

# Defensive rate limits — both APIs allow more, but lower-and-slow is friendlier.
# INGEST_RATE_LIMIT_PER_SEC=5
# INGEST_REQUEST_TIMEOUT_SEC=10

# --- paths (Colab / Cloud overrides) ---
# Redirect data_dir without touching code.
# MYBOOKREC_DATA_DIR=/Volumes/external/mybookrec/data
# MYBOOKREC_CHECKPOINTS_DIR=/Volumes/external/mybookrec/checkpoints

# --- embeddings ---
# Swap to "sentence-transformers/all-mpnet-base-v2" once MPNet artifacts are in place.
# EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- FastAPI serving (mybookrec.serve) ---
# SERVE_HOST=0.0.0.0
# SERVE_PORT=8000
# SERVE_DEFAULT_TOP_K=10
# SERVE_OVERSAMPLE=5
# SERVE_MIN_AVG_RATING=3.5
# Set if you want the server to load a specific checkpoint instead of
# checkpoints/two_tower_mac.pt.
# SERVE_MODEL_PATH=checkpoints/two_tower_v4bce_best.pt
# SERVE_INDEX_PATH=checkpoints/two_tower_v4bce_best_index.faiss
